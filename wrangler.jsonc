{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "job-copilot",
  "compatibility_date": "2025-12-01",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "PYTHON_SERVICE_URL": "https://pdf-parser-service-y24s.onrender.com",
    "FEISHU_APP_ID": "",
    "FEISHU_APP_SECRET": "",
    "FEISHU_APP_TOKEN": "",
    "FEISHU_TABLE_ID": "",
    "FEISHU_ENABLED": "true"
  }
}
