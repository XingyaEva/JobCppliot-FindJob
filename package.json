{
  "name": "job-copilot",
  "version": "0.2.0",
  "description": "智能求职助手 - AI驱动的JD解析、简历匹配、面试准备工具",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.client.config.ts",
    "dev:server": "vite --config vite.config.ts",
    "dev:sandbox": "npm run build && wrangler pages dev dist --ip 0.0.0.0 --port 8080",
    "build:client": "vite build --config vite.client.config.ts",
    "build:worker": "vite build --config vite.config.ts",
    "build": "npm run build:worker && npm run build:client && npm run build:routes",
    "build:routes": "echo '{\"version\":1,\"include\":[\"/*\"],\"exclude\":[\"/assets/*\",\"/static/*\"]}' > dist/_routes.json",
    "preview": "wrangler pages dev dist --ip 0.0.0.0 --port 8080",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name job-copilot",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 8080/tcp 2>/dev/null || true",
    "test": "curl http://localhost:8080/api/health",
    "test:api": "curl -X POST http://localhost:8080/api/test -H 'Content-Type: application/json' -d '{\"message\": \"你好\"}'",
    "clean": "rm -rf dist",
    "git:init": "git init && git add . && git commit -m 'Initial commit'",
    "git:commit": "git add . && git commit -m"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.6.0",
    "hono": "^4.11.3",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.487.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.7",
    "react-router": "^7.13.0",
    "recharts": "^2.15.2",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "tw-animate-css": "^1.3.8",
    "vaul": "^1.1.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@tailwindcss/vite": "^4.1.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.1.12",
    "vite": "^6.3.5",
    "wrangler": "^4.58.0"
  },
  "keywords": [
    "job-assistant",
    "ai",
    "resume",
    "interview",
    "hono",
    "cloudflare-pages",
    "react",
    "shadcn"
  ],
  "author": "",
  "license": "MIT"
}
