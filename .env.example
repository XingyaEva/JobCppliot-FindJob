# ============================================
# FindJob 环境变量配置
# 复制此文件为 .env.local 并填入真实值
# ============================================

# ---------- 应用基础 ----------
NODE_ENV=development
# 前端访问的 API 地址（开发时通常是 localhost）
VITE_API_BASE_URL=http://localhost:8080/api

# ---------- AI 模型 ----------
# OpenAI API（必填，核心 AI 功能依赖）
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
# 默认模型（可选：gpt-4, gpt-4-turbo, gpt-3.5-turbo）
OPENAI_MODEL=gpt-4

# Claude API（可选，备用模型）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ---------- 数据库（Phase 2 升级后启用）----------
# 阿里云 RDS PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/findjob?sslmode=require

# ---------- 认证（Phase 3 升级后启用）----------
# JWT 密钥
# JWT_SECRET=your-random-secret-at-least-32-chars
# JWT_EXPIRES_IN=7d

# 阿里云短信服务（手机号登录）
# ALIYUN_SMS_ACCESS_KEY_ID=
# ALIYUN_SMS_ACCESS_KEY_SECRET=
# ALIYUN_SMS_SIGN_NAME=FindJob
# ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxx

# 微信登录（需企业主体）
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# ---------- 文件存储（Phase 4 升级后启用）----------
# 阿里云 OSS
# ALIYUN_OSS_ACCESS_KEY_ID=
# ALIYUN_OSS_ACCESS_KEY_SECRET=
# ALIYUN_OSS_BUCKET=findjob-files
# ALIYUN_OSS_REGION=oss-cn-hangzhou
# ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# ---------- 监控与分析（Phase 6 升级后启用）----------
# Sentry 错误监控
# SENTRY_DSN=https://xxx@sentry.io/xxx
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# PostHog 用户分析
# POSTHOG_API_KEY=phc_xxx
# VITE_POSTHOG_API_KEY=phc_xxx
# VITE_POSTHOG_HOST=https://app.posthog.com

# ---------- 支付（Phase 7，需企业主体后启用）----------
# 微信支付
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_API_KEY=
# WECHAT_PAY_CERT_PATH=
# WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payments/wechat/callback

# 支付宝
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_NOTIFY_URL=https://your-domain.com/api/payments/alipay/callback

# ---------- 飞书集成（可选）----------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=
FEISHU_ENABLED=false

# ---------- PDF 解析服务（可选）----------
PYTHON_SERVICE_URL=https://pdf-parser-service-y24s.onrender.com
